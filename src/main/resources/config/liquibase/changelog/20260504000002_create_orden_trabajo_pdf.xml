<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260504000002-1" author="taller">
        <createTable tableName="orden_trabajo_pdf">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="orden_trabajo_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="nombre_archivo" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_generacion" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="contenido" type="longblob">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="orden_trabajo_pdf"
            baseColumnNames="orden_trabajo_id"
            constraintName="fk_orden_trabajo_pdf_orden"
            referencedTableName="orden_trabajo"
            referencedColumnNames="id"
            onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
